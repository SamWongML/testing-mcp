{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm compile:*)",
      "Bash(pnpm atp:*)",
      "Bash(pnpm format:check:*)",
      "Bash(pnpm exec vitest:*)",
      "Bash(pnpm exec tsc:*)",
      "Bash(pnpm exec eslint:*)",
      "Bash(pnpm --filter:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)"
    ],
    "deny": ["Read(./pnpm-lock.yaml)", "Read(./**/coverage/**)", "Read(./**/*.tsbuildinfo)"]
  }
}
